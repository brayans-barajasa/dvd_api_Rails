{
  "openapi": "3.0.1",
  "info": {
    "title": "DVD API",
    "version": "v1"
  },
  "paths": {
    "/api/v1/actors": {
      "get": {
        "summary": "List all actors",
        "tags": [
          "Actors"
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Filter actors by search term",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "actors found"
          }
        }
      }
    },
    "/api/v1/actors/{id}": {
      "get": {
        "summary": "Show an actor",
        "tags": [
          "Actors"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Actor ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "actor found"
          },
          "404": {
            "description": "actor not found"
          }
        }
      }
    },
    "/api/v1/cities": {
      "get": {
        "summary": "list cities",
        "tags": [
          "Cities"
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Buscar por nombre de ciudad",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "country_id",
            "in": "query",
            "description": "Filtrar por ID de país",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "city_id": {
                        "type": "integer"
                      },
                      "city": {
                        "type": "string"
                      },
                      "country_id": {
                        "type": "integer"
                      }
                    },
                    "required": [
                      "city_id",
                      "city",
                      "country_id"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/countries/{country_id}/cities": {
      "get": {
        "summary": "list cities for a country",
        "tags": [
          "Cities"
        ],
        "parameters": [
          {
            "name": "country_id",
            "in": "path",
            "description": "ID del país",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "city_id": {
                        "type": "integer"
                      },
                      "city": {
                        "type": "string"
                      },
                      "country_id": {
                        "type": "integer"
                      }
                    },
                    "required": [
                      "city_id",
                      "city",
                      "country_id"
                    ]
                  }
                }
              }
            }
          },
          "404": {
            "description": "country not found"
          }
        }
      }
    },
    "/api/v1/cities/{id}": {
      "get": {
        "summary": "show city",
        "tags": [
          "Cities"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID de la ciudad",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "city_id": {
                      "type": "integer"
                    },
                    "city": {
                      "type": "string"
                    },
                    "country_id": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "city_id",
                    "city",
                    "country_id"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "city not found"
          }
        }
      }
    },
    "/api/v1/clients": {
      "get": {
        "summary": "Lista todos los clientes",
        "tags": [
          "Clients"
        ],
        "responses": {
          "200": {
            "description": "Lista obtenida"
          }
        }
      },
      "post": {
        "summary": "Crea un cliente",
        "tags": [
          "Clients"
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "Cliente creado"
          },
          "422": {
            "description": "Error de validación"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                },
                "required": [
                  "first_name",
                  "last_name",
                  "email"
                ]
              }
            }
          }
        }
      }
    },
    "/api/v1/clients/{id}": {
      "get": {
        "summary": "Muestra un cliente",
        "tags": [
          "Clients"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cliente encontrado"
          },
          "404": {
            "description": "Cliente no encontrado"
          }
        }
      },
      "put": {
        "summary": "Actualiza un cliente",
        "tags": [
          "Clients"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cliente actualizado"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Elimina un cliente",
        "tags": [
          "Clients"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cliente eliminado"
          }
        }
      }
    },
    "/api/v1/inventories": {
      "get": {
        "summary": "Lista inventarios",
        "tags": [
          "Inventories"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Página",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Resultados por página",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "inventarios encontrados"
          }
        }
      }
    },
    "/api/v1/inventories/{id}": {
      "get": {
        "summary": "Muestra un inventario",
        "tags": [
          "Inventories"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID del inventario",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "inventario encontrado"
          },
          "404": {
            "description": "no encontrado"
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor local"
    }
  ]
}